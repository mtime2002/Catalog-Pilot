    private static string ResolveValue(params string?[] values)
    {
        foreach (var value in values)
        {
            if (!string.IsNullOrWhiteSpace(value))
            {
                return value.Trim();
            }
        }

        return string.Empty;
    }

    private static string NormalizeBarcodeValue(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return new string(value
            .Where(char.IsLetterOrDigit)
            .Select(char.ToUpperInvariant)
            .ToArray());
    }

    private static IReadOnlyList<string> ExpandBarcodeLookupCodes(string normalizedCode)
    {
        if (string.IsNullOrWhiteSpace(normalizedCode))
        {
            return [];
        }

        var expanded = new List<string>(4);
        var seen = new HashSet<string>(StringComparer.OrdinalIgnoreCase);

        static void AddCode(List<string> list, HashSet<string> set, string value)
        {
            if (string.IsNullOrWhiteSpace(value) || !set.Add(value))
            {
                return;
            }

            list.Add(value);
        }

        AddCode(expanded, seen, normalizedCode);

        if (normalizedCode.Length == 12 && IsUpcAChecksumValid(normalizedCode))
        {
            var ean13 = $"0{normalizedCode}";
            if (IsEanChecksumValid(ean13))
            {
                AddCode(expanded, seen, ean13);
            }
        }
        else if (normalizedCode.Length == 13 &&
                 normalizedCode.StartsWith('0') &&
                 IsEanChecksumValid(normalizedCode))
        {
            var upca = normalizedCode[1..];
            if (IsUpcAChecksumValid(upca))
            {
                AddCode(expanded, seen, upca);
            }
        }
        else if (normalizedCode.Length == 8 && TryExpandUpceToUpca(normalizedCode, out var upceAsUpca))
        {
            AddCode(expanded, seen, upceAsUpca);
            var ean13 = $"0{upceAsUpca}";
            if (IsEanChecksumValid(ean13))
            {
                AddCode(expanded, seen, ean13);
            }
        }

        return expanded;
    }

    private static bool IsEanChecksumValid(string code)
    {
        if (!code.All(char.IsDigit) || code.Length != 13)
        {
            return false;
        }

        var expected = code[^1] - '0';
        var sum = 0;
        for (var i = 0; i < 12; i++)
        {
            var digit = code[i] - '0';
            sum += i % 2 == 0 ? digit : digit * 3;
        }

        return (10 - (sum % 10)) % 10 == expected;
    }

    private static bool IsUpcAChecksumValid(string code)
    {
        if (!code.All(char.IsDigit) || code.Length != 12)
        {
            return false;
        }

        var expected = code[^1] - '0';
        var oddSum = 0;
        var evenSum = 0;
        for (var i = 0; i < 11; i++)
        {
            var digit = code[i] - '0';
            if (i % 2 == 0)
            {
                oddSum += digit;
            }
            else
            {
                evenSum += digit;
            }
        }

        var check = (10 - (((oddSum * 3) + evenSum) % 10)) % 10;
        return check == expected;
    }

    private static bool TryExpandUpceToUpca(string upce, out string upca)
    {
        upca = string.Empty;
        if (string.IsNullOrWhiteSpace(upce) || upce.Length != 8 || !upce.All(char.IsDigit))
        {
            return false;
        }

        var ns = upce[0];
        var d1 = upce[1];
        var d2 = upce[2];
        var d3 = upce[3];
        var d4 = upce[4];
        var d5 = upce[5];
        var d6 = upce[6];
        var check = upce[7];

        string body = d6 switch
        {
            '0' or '1' or '2' => $"{ns}{d1}{d2}{d6}0000{d3}{d4}{d5}",
            '3' => $"{ns}{d1}{d2}{d3}00000{d4}{d5}",
            '4' => $"{ns}{d1}{d2}{d3}{d4}00000{d5}",
            _ => $"{ns}{d1}{d2}{d3}{d4}{d5}0000{d6}"
        };

        var candidate = $"{body}{check}";
        if (!IsUpcAChecksumValid(candidate))
        {
            return false;
        }

        upca = candidate;
        return true;
    }

    private static void MergeScanCandidate(
        IDictionary<string, ExternalBarcodeLookupResult> merged,
        ExternalBarcodeLookupResult candidate)
    {
        if (string.IsNullOrWhiteSpace(candidate.Title))
        {
            return;
        }

        var key = $"{candidate.Title.Trim().ToLowerInvariant()}|{(candidate.Platform ?? string.Empty).Trim().ToLowerInvariant()}";
        if (!merged.TryGetValue(key, out var existing))
        {
            merged[key] = candidate;
            return;
        }

        if (candidate.Confidence > existing.Confidence)
        {
            merged[key] = candidate;
        }
    }

    private static void MergeScanCandidateList(
        IList<ExternalBarcodeLookupResult> list,
        ExternalBarcodeLookupResult candidate)
    {
        if (string.IsNullOrWhiteSpace(candidate.Title))
        {
            return;
        }

        var normalizedTitle = candidate.Title.Trim().ToLowerInvariant();
        var normalizedPlatform = (candidate.Platform ?? string.Empty).Trim().ToLowerInvariant();
        for (var i = 0; i < list.Count; i++)
        {
            var existing = list[i];
            if (!existing.Title.Trim().ToLowerInvariant().Equals(normalizedTitle, StringComparison.Ordinal) ||
                !(existing.Platform ?? string.Empty).Trim().ToLowerInvariant().Equals(normalizedPlatform, StringComparison.Ordinal))
            {
                continue;
            }

            if (candidate.Confidence > existing.Confidence)
            {
                list[i] = candidate;
            }

            return;
        }

        list.Add(candidate);
    }

    private static void ApplyClassificationDefaults(ListingInput input, ClassificationResult classification)
    {
        if (string.IsNullOrWhiteSpace(input.ItemName) &&
            !string.IsNullOrWhiteSpace(classification.SuggestedTitle))
        {
            input.ItemName = classification.SuggestedTitle;
        }

        if (string.IsNullOrWhiteSpace(input.Platform))
        {
            if (!string.IsNullOrWhiteSpace(classification.BankMatchedPlatform))
            {
                input.Platform = classification.BankMatchedPlatform;
            }
            else if (!string.IsNullOrWhiteSpace(classification.SuggestedPlatform))
            {
                input.Platform = classification.SuggestedPlatform;
            }
        }

        if (string.IsNullOrWhiteSpace(input.Condition) && !string.IsNullOrWhiteSpace(classification.SuggestedCondition))
        {
            input.Condition = classification.SuggestedCondition;
        }
    }

