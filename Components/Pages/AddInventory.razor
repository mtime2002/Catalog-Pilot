    {
        var draft = CreateDraft(insertAtTop: true);
        draft.Message = "Scan a barcode to auto-fill this draft.";
        draft.ErrorMessage = string.Empty;
        _scannerAddDirectMode = false;
        _scannerDraftId = draft.Id;
        _scannerOpen = true;
        _scannerPendingStart = true;
        _scannerStatus = "Starting camera...";
