    }

    private async Task StartBarcodeScannerAsync()
    {
        if (!_scannerOpen || !_scannerDraftId.HasValue)
        {
            return;
        }

        try
        {
            _scannerDotNetRef ??= DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("catalogPilotBarcodeScanner.start", _scannerDotNetRef, BarcodeScannerVideoId);
            _scannerStatus = "Point camera at a UPC/EAN barcode.";
        }
        catch (Exception ex)
        {
            _scannerStatus = "Unable to start camera scanner.";
            _errorMessage = ex.Message;
        }

        await InvokeAsync(StateHasChanged);
    }

    private async Task CloseBarcodeScannerAsync()
    {
        _scannerOpen = false;
        _scannerPendingStart = false;
        _scannerDraftId = null;
        _scannerAddDirectMode = false;
        _scannerStatus = string.Empty;

        try
        {
            await JSRuntime.InvokeVoidAsync("catalogPilotBarcodeScanner.stop", BarcodeScannerVideoId);
        }
        catch
        {
            // Ignore scanner shutdown errors.
        }

        await InvokeAsync(StateHasChanged);
    }

    [JSInvokable]
    public async Task OnCameraBarcodeDetected(string rawValue, string format)
    {
        var draftId = _scannerDraftId;
        var addDirectMode = _scannerAddDirectMode;
        await CloseBarcodeScannerAsync();
        await PrepareScanResultChoicesAsync(rawValue, format, draftId, addDirectMode);
    }

    [JSInvokable]
    public Task OnCameraBarcodeError(string message)
    {
        _scannerStatus = string.IsNullOrWhiteSpace(message)
            ? "Camera barcode scanning is unavailable in this browser."
            : message;
        return InvokeAsync(StateHasChanged);
    }

    private async Task PrepareScanResultChoicesAsync(
        string rawValue,
        string format,
        Guid? draftId,
        bool addDirectMode)
    {
        var workingDraftId = draftId;
        if (!workingDraftId.HasValue)
        {
            var created = CreateDraft(insertAtTop: true);
            created.Message = "Scanning barcode...";
            created.ErrorMessage = string.Empty;
            workingDraftId = created.Id;
            await PersistDraftsAsync();
        }

        var normalized = NormalizeBarcodeValue(rawValue);
        if (string.IsNullOrWhiteSpace(normalized))
        {
            _errorMessage = "Scanned barcode was empty.";
            _statusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _errorMessage = string.Empty;
        _statusMessage = $"Scanned {normalized}. Finding possible matches...";

        // Open picker immediately with a loading state so the user sees progress while lookups run.
        OpenScanResultPickerLoading(normalized, format, workingDraftId.Value, addDirectMode: false);
        await InvokeAsync(StateHasChanged);

        try
        {
            var draft = _drafts.FirstOrDefault(item => item.Id == workingDraftId.Value);
            var platformHint = draft?.Input.Platform;

            var mergedCandidates = new Dictionary<string, ExternalBarcodeLookupResult>(StringComparer.Ordinal);
            var lookupCodes = ExpandBarcodeLookupCodes(normalized);
            foreach (var lookupCode in lookupCodes.Take(5))
            {
                var catalogMatch = await GameCatalogStore.FindByBarcodeAsync(lookupCode, platformHint);
                if (catalogMatch is not null)
                {
                    var fromCatalog = new ExternalBarcodeLookupResult
                    {
                        Code = lookupCode,
                        Title = catalogMatch.Match.Entry.Title,
                        Platform = catalogMatch.Match.Entry.Platform,
                        Franchise = catalogMatch.Match.Entry.Franchise,
                        Provider = "Local Catalog",
                        Confidence = decimal.Min(0.99m, decimal.Max(0.82m, catalogMatch.Match.Score))
                    };
                    MergeScanCandidate(mergedCandidates, fromCatalog);
                }

                var externalCandidates = await ExternalBarcodeLookupService.LookupCandidatesAsync(
                    lookupCode,
                    platformHint,
                    maxResults: 8);
                foreach (var candidate in externalCandidates)
                {
                    var withCode = string.IsNullOrWhiteSpace(candidate.Code)
                        ? candidate with { Code = lookupCode }
                        : candidate;
                    MergeScanCandidate(mergedCandidates, withCode);
                }
            }

            var draftTitleSeed = ResolveValue(
                draft?.Input.ItemName,
                draft?.SuggestedClassification?.SuggestedTitle,
                draft?.SuggestedClassification?.BankMatchedTitle);
            if (!string.IsNullOrWhiteSpace(draftTitleSeed))
            {
                var seedMatches = await GameCatalogStore.SearchSimilarTitlesAsync(
                    draftTitleSeed,
                    platformHint,
                    maxResults: 8);
                foreach (var match in seedMatches)
                {
                    var fromSeed = new ExternalBarcodeLookupResult
                    {
                        Code = normalized,
                        Title = match.Entry.Title,
                        Platform = match.Entry.Platform,
                        Franchise = match.Entry.Franchise,
                        Provider = "Draft OCR Catalog",
                        Confidence = decimal.Min(0.97m, decimal.Max(0.70m, match.Score + 0.12m))
                    };
                    MergeScanCandidate(mergedCandidates, fromSeed);
                }
            }

            var candidates = mergedCandidates.Values
                .OrderByDescending(candidate => candidate.Confidence)
                .ThenBy(candidate => candidate.Title, StringComparer.OrdinalIgnoreCase)
                .Take(20)
                .ToArray();

            ApplyScanResultCandidates(candidates);
            _statusMessage = candidates.Length == 0
                ? $"Scanned {normalized}. No automatic matches found."
                : $"Scanned {normalized}. {candidates.Length} match option(s) found.";
            _errorMessage = string.Empty;
        }
        catch (Exception ex)
        {
            _scanResultPickerLoading = false;
            _errorMessage = ex.Message;
            _statusMessage = string.Empty;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private void OpenScanResultPickerLoading(
        string normalizedBarcode,
        string format,
        Guid? draftId,
        bool addDirectMode)
    {
        var draft = draftId.HasValue
            ? _drafts.FirstOrDefault(item => item.Id == draftId.Value)
            : null;
        _scanResultBarcode = normalizedBarcode;
        _scanResultFormat = format ?? string.Empty;
        _scanResultDraftId = draftId;
        _scanResultAddDirectMode = addDirectMode;
        _scanResultTitleQuery = ResolveValue(
            draft?.Input.ItemName,
            draft?.SuggestedClassification?.BankMatchedTitle,
            draft?.SuggestedClassification?.SuggestedTitle);
        _scanResultTitleSearchBusy = false;
        _scanResultSubmitting = false;
        _scanResultPickerLoading = true;
        _scanResultCandidates.Clear();
        _scanResultPickerOpen = true;
    }

    private void ApplyScanResultCandidates(IReadOnlyList<ExternalBarcodeLookupResult> candidates)
    {
        _scanResultCandidates.Clear();
        _scanResultCandidates.AddRange(candidates.Take(20));
        _scanResultPickerLoading = false;
    }

    private void CloseScanResultPicker()
    {
        _scanResultPickerOpen = false;
        _scanResultPickerLoading = false;
        _scanResultSubmitting = false;
        _scanResultAddDirectMode = false;
        _scanResultDraftId = null;
        _scanResultBarcode = string.Empty;
        _scanResultFormat = string.Empty;
        _scanResultTitleQuery = string.Empty;
        _scanResultTitleSearchBusy = false;
        _scanResultCandidates.Clear();
    }

    private async Task SearchScanResultTitlesAsync()
    {
        if (!_scanResultPickerOpen || _scanResultTitleSearchBusy || _scanResultPickerLoading)
        {
            return;
        }

        var query = _scanResultTitleQuery.Trim();
        if (string.IsNullOrWhiteSpace(query))
        {
            _errorMessage = "Enter a title to search the catalog.";
            _statusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _scanResultTitleSearchBusy = true;
        _errorMessage = string.Empty;
        try
        {
            string? platformHint = null;
            if (_scanResultDraftId.HasValue)
            {
                platformHint = _drafts.FirstOrDefault(item => item.Id == _scanResultDraftId.Value)?.Input.Platform;
            }

            var matches = await GameCatalogStore.SearchSimilarTitlesAsync(query, platformHint, maxResults: 12);
            foreach (var match in matches)
            {
                var fromSearch = new ExternalBarcodeLookupResult
                {
                    Code = _scanResultBarcode,
                    Title = match.Entry.Title,
                    Platform = match.Entry.Platform,
                    Franchise = match.Entry.Franchise,
                    Provider = "Catalog Search",
                    Confidence = decimal.Min(0.98m, decimal.Max(0.66m, match.Score + 0.15m))
                };
                MergeScanCandidateList(_scanResultCandidates, fromSearch);
            }

            _scanResultCandidates.Sort(static (left, right) =>
            {
                var compare = right.Confidence.CompareTo(left.Confidence);
                if (compare != 0)
                {
                    return compare;
                }

                return string.Compare(left.Title, right.Title, StringComparison.OrdinalIgnoreCase);
            });

            _statusMessage = matches.Count == 0
                ? "No catalog title matches found."
                : $"Added {matches.Count} catalog search match(es).";
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _statusMessage = string.Empty;
        }
        finally
        {
            _scanResultTitleSearchBusy = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task SkipScanResultAsync()
    {
        var draftId = _scanResultDraftId;
        var normalized = _scanResultBarcode;
        var format = _scanResultFormat;

        CloseScanResultPicker();

        if (draftId.HasValue && !string.IsNullOrWhiteSpace(normalized))
        {
            await ApplyScannedNoMatchAsync(draftId.Value, normalized, format);
        }
    }

    private async Task SelectScanResultAsync(ExternalBarcodeLookupResult candidate)
    {
        if (_scanResultSubmitting)
        {
            return;
        }

        _scanResultSubmitting = true;
        var draftId = _scanResultDraftId;
        var normalized = _scanResultBarcode;
        var format = _scanResultFormat;
        CloseScanResultPicker();

        if (string.IsNullOrWhiteSpace(normalized))
        {
            _errorMessage = "Scanned barcode was empty.";
            _statusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        if (!draftId.HasValue)
        {
            _errorMessage = "No draft target was available for scan results.";
            _statusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        await ApplyScannedLookupAsync(draftId.Value, normalized, format, candidate);
    }

    private async Task ApplyScannedNoMatchAsync(Guid draftId, string normalized, string format)
    {
        var draft = _drafts.FirstOrDefault(item => item.Id == draftId);
        if (draft is null)
        {
            return;
        }

        RequestDraftAnalysisCancellation(draft);
        draft.AnalysisVersion++;
        draft.IsAnalyzing = false;
        draft.AnalysisCts = null;
        draft.ErrorMessage = string.Empty;
        UpsertAttributeRow(draft, "Detected Game Code", normalized);
        if (!string.IsNullOrWhiteSpace(format))
        {
            UpsertAttributeRow(draft, "Barcode Format", format);
        }

        draft.Message = $"Scanned {normalized}, but no game match was selected.";
        await PersistDraftsAsync();
        await InvokeAsync(StateHasChanged);
    }

    private async Task ApplyScannedLookupAsync(Guid draftId, string normalized, string format, ExternalBarcodeLookupResult lookup)
    {
        var draft = _drafts.FirstOrDefault(item => item.Id == draftId);
        if (draft is null)
        {
            return;
        }

        RequestDraftAnalysisCancellation(draft);
        draft.AnalysisVersion++;
        draft.IsAnalyzing = false;
        draft.AnalysisCts = null;
        draft.ErrorMessage = string.Empty;
        draft.Message = $"Applying selected match for {normalized}...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var classification = BuildScannedBarcodeClassification(draft.Input, lookup, normalized, format);
            draft.SuggestedClassification = classification;
            ApplyClassificationDefaults(draft.Input, classification);
            MergeSuggestedAttributes(draft, classification.ItemSpecifics);

            var pricingInput = CloneListingInput(draft.Input);
            ApplyClassificationDefaults(pricingInput, classification);
            draft.SuggestedPricing = await PricingService.SuggestPriceAsync(pricingInput, classification);

            draft.Message = $"Barcode matched: {DisplayOrFallback(classification.SuggestedTitle)}.";
            draft.ErrorMessage = string.Empty;
            _statusMessage = "Applied selected scan match.";
            _errorMessage = string.Empty;
            await PersistDraftsAsync();
        }
        catch (Exception ex)
        {
            draft.ErrorMessage = ex.Message;
            draft.Message = string.Empty;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AddNewItemFromBarcodeAsync(string rawValue, string format)
    {
        if (!_authLoaded || _currentUserId == Guid.Empty)
        {
            _errorMessage = "You must be signed in to add items.";
            _statusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var normalized = NormalizeBarcodeValue(rawValue);
        if (string.IsNullOrWhiteSpace(normalized))
        {
            _errorMessage = "Scanned barcode was empty.";
            _statusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        _errorMessage = string.Empty;
        _statusMessage = $"Scanned {normalized}. Looking up catalog match...";
        await InvokeAsync(StateHasChanged);

        try
        {
            var lookup = await ExternalBarcodeLookupService.LookupAsync(normalized);
            if (lookup is null || string.IsNullOrWhiteSpace(lookup.Title))
            {
                _errorMessage = $"Scanned {normalized}, but no game match was found.";
                _statusMessage = string.Empty;
                await InvokeAsync(StateHasChanged);
                return;
            }

            await AddNewItemFromLookupAsync(normalized, format, lookup);
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _statusMessage = string.Empty;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task AddNewItemFromLookupAsync(string normalized, string format, ExternalBarcodeLookupResult lookup)
    {
        if (!_authLoaded || _currentUserId == Guid.Empty)
        {
            _errorMessage = "You must be signed in to add items.";
            _statusMessage = string.Empty;
            await InvokeAsync(StateHasChanged);
            return;
        }

        var input = new ListingInput
        {
            ItemName = lookup.Title.Trim(),
            Platform = (lookup.Platform ?? string.Empty).Trim(),
            Condition = "Used",
            Quantity = 1
        };

        try
        {
            var classification = BuildScannedBarcodeClassification(input, lookup, normalized, format);
            ApplyClassificationDefaults(input, classification);

            var pricingInput = CloneListingInput(input);
            ApplyClassificationDefaults(pricingInput, classification);
            var pricing = await PricingService.SuggestPriceAsync(pricingInput, classification);

            var saved = await InventoryStore.AddItemAsync(
                _currentUserId,
                input,
                classification,
                pricing);

            _sessionAddedItems.Add(new SessionAddedItem
            {
                ItemName = saved.Input.ItemName,
                Platform = saved.Input.Platform,
                Quantity = saved.Input.Quantity,
                Status = saved.Status,
                AddedUtc = DateTimeOffset.UtcNow
            });

            _statusMessage = $"Added from scan: {saved.Input.ItemName} ({saved.Status}).";
            _errorMessage = string.Empty;
            await PersistDraftsAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
            _statusMessage = string.Empty;
        }
        finally
        {
            await InvokeAsync(StateHasChanged);
        }
    }

    public async ValueTask DisposeAsync()
    {
        CancelAllDraftAnalyses();

        try
        {
            await CloseBarcodeScannerAsync();
        }
        catch
        {
            // Ignore scanner shutdown errors during dispose.
        }
        _scannerDotNetRef?.Dispose();

        if (_autosaveCts is not null)
        {
            try
            {
                _autosaveCts.Cancel();
            }
            catch
            {
                // Ignore cancellation failures during dispose.
            }
        }

        if (_autosaveTask is not null)
        {
            try
            {
                await _autosaveTask;
            }
            catch
            {
                // Ignore autosave shutdown errors during dispose.
            }
        }

        if (_cacheReady)
        {
            try
            {
                await PersistDraftsCoreAsync();
            }
            catch
            {
                // Ignore final persistence failures during dispose.
            }
        }

        _autosaveCts?.Dispose();
    }

    private static void RequestDraftAnalysisCancellation(InventoryDraft draft)
    {
        if (draft.AnalysisCts is null)
        {
            return;
        }

        try
        {
            draft.AnalysisCts.Cancel();
        }
        catch
        {
            // Ignore cancellation failures.
        }
    }

    private void CancelAllDraftAnalyses()
    {
        foreach (var draft in _drafts)
        {
            RequestDraftAnalysisCancellation(draft);
        }
    }

    private async Task<bool> ConfirmAsync(string prompt)
    {
        try
        {
            return await JSRuntime.InvokeAsync<bool>("confirm", prompt);
        }
        catch
        {
            return false;
        }
    }

    private void StartDraftAutosave()
    {
        if (_autosaveTask is not null)
        {
            return;
        }

        _autosaveCts = new CancellationTokenSource();
        _autosaveTask = Task.Run(() => RunDraftAutosaveAsync(_autosaveCts.Token));
    }

    private async Task RunDraftAutosaveAsync(CancellationToken cancellationToken)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(4));
        try
        {
            while (await timer.WaitForNextTickAsync(cancellationToken))
            {
                await InvokeAsync(PersistDraftsCoreAsync);
            }
        }
        catch (OperationCanceledException)
        {
            // Normal shutdown.
        }
    }

    private Task PersistDraftsAsync()
    {
        return InvokeAsync(PersistDraftsCoreAsync);
    }

    private async Task PersistDraftsCoreAsync()
    {
        if (!_cacheReady)
        {
            return;
        }

        try
        {
            var snapshot = new DraftCacheSnapshot
            {
                Drafts = _drafts.Select(ToCachedDraft).ToList(),
                SessionAddedItems = _sessionAddedItems
                    .OrderBy(item => item.AddedUtc)
                    .Select(item => new SessionAddedItem
                    {
                        ItemName = item.ItemName,
                        Platform = item.Platform,
                        Quantity = item.Quantity,
                        Status = item.Status,
                        AddedUtc = item.AddedUtc
                    })
                    .ToList()
            };

            var json = JsonSerializer.Serialize(snapshot, _cacheJsonOptions);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", DraftCacheKey, json);
        }
        catch
        {
            // Ignore local cache persistence errors.
        }
    }

    private async Task RestoreDraftsFromCacheAsync()
    {
        try
        {
            var raw = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", DraftCacheKey);
            if (!string.IsNullOrWhiteSpace(raw))
            {
                var snapshot = JsonSerializer.Deserialize<DraftCacheSnapshot>(raw, _cacheJsonOptions);
                if (snapshot is not null)
                {
                    _drafts.Clear();
                    foreach (var cached in snapshot.Drafts.Take(40))
                    {
                        _drafts.Add(FromCachedDraft(cached));
                    }

                    if (_drafts.Count == 0)
                    {
                        _drafts.Add(new InventoryDraft());
                    }

                    _sessionAddedItems.Clear();
                    foreach (var item in snapshot.SessionAddedItems.Take(200))
                    {
                        _sessionAddedItems.Add(new SessionAddedItem
                        {
                            ItemName = item.ItemName,
                            Platform = item.Platform,
                            Quantity = item.Quantity,
                            Status = item.Status,
                            AddedUtc = item.AddedUtc
                        });
                    }

                    if (snapshot.Drafts.Count > 0)
                    {
                        _statusMessage = $"Recovered {snapshot.Drafts.Count} draft item(s) from local cache.";
                    }
                }
            }
        }
        catch
        {
            // Ignore cache restore failures and continue with empty drafts.
        }
        finally
        {
            _cacheReady = true;
            try
            {
                await PersistDraftsCoreAsync();
            }
            catch
            {
                // Ignore initial cache write failures.
            }
            await InvokeAsync(StateHasChanged);
        }
    }

    private static void ResetDraft(InventoryDraft draft)
    {
        draft.Input = new ListingInput
        {
            Condition = "Used",
            Quantity = 1
        };
        draft.AttributeRows.Clear();
        draft.SuggestedClassification = null;
        draft.SuggestedPricing = null;
        draft.AnalysisVersion++;
        draft.AnalysisCts = null;
        draft.PendingUserId = Guid.Empty;
        draft.SavedInventoryItemId = null;
        draft.PostSaveAutofillState = null;
        draft.PostSaveAutofillCompleted = false;
        draft.ShowAttributes = false;
        draft.ShowPhotoSourcePicker = false;
        draft.ShowTitlePicker = false;
        draft.TitleSearchQuery = string.Empty;
        draft.TitleSearchResults.Clear();
        draft.TitleSearchBusy = false;
        draft.TitleSearchStatus = string.Empty;
        draft.IsAnalyzing = false;
        draft.IsSaving = false;
    }

    private static CachedInventoryDraft ToCachedDraft(InventoryDraft draft)
    {
        return new CachedInventoryDraft
        {
            Id = draft.Id,
            Input = CloneListingInput(draft.Input),
            AttributeRows = draft.AttributeRows
                .Select(row => new DraftAttributeRow
                {
                    Id = row.Id,
                    Key = row.Key,
                    Value = row.Value
                })
                .ToList(),
            ShowAttributes = draft.ShowAttributes
        };
    }

    private static InventoryDraft FromCachedDraft(CachedInventoryDraft cached)
    {
        var input = cached.Input is null
            ? new ListingInput
            {
                Condition = "Used",
                Quantity = 1
            }
            : CloneListingInput(cached.Input);

        if (string.IsNullOrWhiteSpace(input.Condition))
        {
            input.Condition = "Used";
        }

        input.Quantity = Math.Clamp(input.Quantity, 1, 20);

        return new InventoryDraft
        {
            Id = cached.Id == Guid.Empty ? Guid.NewGuid() : cached.Id,
            Input = input,
            AttributeRows = cached.AttributeRows
                .Select(row => new DraftAttributeRow
                {
                    Id = row.Id == Guid.Empty ? Guid.NewGuid() : row.Id,
                    Key = row.Key,
                    Value = row.Value
                })
                .ToList(),
            ShowAttributes = cached.ShowAttributes
        };
    }

