@page "/"

<PageTitle>CatalogPilot</PageTitle>

<main class="page-shell">
    <header class="panel hero-landing">
        <p class="hero-kicker">eBay Listing Workflow</p>
        <h1>Go from photos to publish-ready eBay listings</h1>
        <p>
            CatalogPilot helps resellers classify games, estimate price ranges, and generate listing payloads fast.
            Run a free account, then unlock subscription features when you need scale.
        </p>
        <div class="button-row" style="margin-top:0.8rem;">
            <a class="btn btn-primary" href="/sign-up">Start Free</a>
            <a class="btn" href="/sign-in">Sign In</a>
        </div>
    </header>

    <section class="content-grid">
        <article class="panel">
            <h2>1) Capture</h2>
            <p class="muted">Upload item photos and let the app infer title, platform, and condition candidates.</p>
        </article>
        <article class="panel">
            <h2>2) Price</h2>
            <p class="muted">Use eBay comps with strategy hints before you publish.</p>
        </article>
        <article class="panel">
            <h2>3) Publish</h2>
            <p class="muted">Create listing drafts or publish directly from a consistent flow.</p>
        </article>
    </section>

    <section class="panel">
        <h2>Pricing</h2>
        <div class="content-grid">
            <article class="panel">
                <h3>Free</h3>
                <p class="price-tag">$0</p>
                <p class="muted">Core listing workflow and account dashboard.</p>
            </article>
            <article class="panel">
                <h3>Pro</h3>
                <p class="price-tag">Subscription</p>
                <p class="muted">Usage expansions and billing portal access through Stripe.</p>
            </article>
        </div>
    </section>
</main>
